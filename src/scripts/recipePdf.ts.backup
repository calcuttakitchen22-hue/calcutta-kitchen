import { jsPDF } from "jspdf";
import html2canvas from "html2canvas";
import logo from "@/assets/images/Hori logo o-w.png";
import watermark from "@/assets/images/pdf-watermark.png";

function drawFooter(pdf: jsPDF) {

  htmlPdf.setFontSize(10);

  htmlPdf.setTextColor(100);

htmlPdf.text(
  "calcuttakitchen.in",
  105,
  285,
  { align: "center" }
);
}

function drawPageBackground(
  pdf: jsPDF,
  watermarkImg: HTMLImageElement
) {

  htmlPdf.setFillColor(248, 245, 230);

  htmlPdf.rect(
    0,
    0,
    210,
    297,
    "F"
  );

htmlPdf.addImage(
  watermarkImg,
  "PNG",
  0,
  -20,
  320,
  320
);
}
async function waitForImage(
  img: HTMLImageElement
) {

  if (img.complete) {
    return;
  }

  await new Promise(resolve => {
    img.onload = () => resolve(true);
    img.onerror = () => resolve(true);
  });
}
console.log("PDF Start");
(window as any).downloadRecipePdf =
async (
  language = "en"
) => {
console.log(
  "PDF FUNCTION CALLED",
  language
);
const pdfRecipe =
  document.getElementById(
    "pdf-recipe"
  ) as HTMLDivElement;

pdfRecipe.style.fontFamily =
  language === "bn"
    ? '"Noto Serif Bengali", serif'
    : 'Futura, sans-serif';
	
const bnDataElement =
  document.getElementById(
    "recipe-bn-data"
  );

const ingredientsContainer =
  document.getElementById(
    "pdf-ingredients"
  );

const methodContainer =
  document.getElementById(
    "pdf-method"
  );

const titleElement =
  document.getElementById(
    "pdf-title"
  );

if (
  ingredientsContainer &&
  methodContainer
) {

  ingredientsContainer.innerHTML = "";
  methodContainer.innerHTML = "";

  const ingredients =
    language === "bn"
      ? JSON.parse(
          bnDataElement?.getAttribute(
            "data-ingredients"
          ) || "[]"
        )
      : Array.from(
          document.querySelectorAll(
            "#ingredients + ul li"
          )
        ).map(
          li =>
            li.textContent?.trim() ||
            ""
        );

  ingredients.forEach(item => {

    const p =
      document.createElement(
        "p"
      );

    p.textContent =
      "• " + item;

    ingredientsContainer.appendChild(
      p
    );
  });

  const method =
    language === "bn"
      ? JSON.parse(
          bnDataElement?.getAttribute(
            "data-method"
          ) || "[]"
        )
      : Array.from(
          document.querySelectorAll(
            "#method + ol li"
          )
        ).map(
          li =>
            li.textContent?.trim() ||
            ""
        );

  method.forEach(
    (
      step,
      index
    ) => {

      const p =
        document.createElement(
          "p"
        );

      p.textContent =
        `${index + 1}. ${step}`;

      methodContainer.appendChild(
        p
      );
    }
  );
}

if (!pdfRecipe) {
  return;
}

pdfRecipe.style.display =
  "block";
  
  const canvas =
  await html2canvas(
    pdfRecipe,
    {
      scale: 2,
      useCORS: true
    }
  );

const imageData =
  canvas.toDataURL(
    "image/jpeg",
    0.9
  );

const htmlPdf =
  new jsPDF(
    "p",
    "mm",
    "a4"
  );

const pdfWidth = 210;

const pdfHeight =
  canvas.height *
  pdfWidth /
  canvas.width;

const margin = 10;

htmlPdf.addImage(
  imageData,
  "JPEG",
  margin,
  margin,
  pdfWidth - (margin * 2),
  pdfHeight
);

htmlPdf.save(
  "test.pdf"
);

pdfRecipe.style.display =
  "none";

return;
  
console.log("PDF START");
  const recipeData =
  document.getElementById(
    "recipe-bn-data"
  );

const title =
  language === "bn"
    ? recipeData?.getAttribute(
        "data-title"
      ) || "রেসিপি"
    : document.querySelector("h1")
        ?.childNodes[0]
        ?.textContent
        ?.trim() || "Recipe";

  const ingredients =
  language === "bn"
    ? JSON.parse(
        recipeData?.getAttribute(
          "data-ingredients"
        ) || "[]"
      )
    : Array.from(
        document.querySelectorAll(
          "#ingredients + ul li"
        )
      ).map(
        li =>
          li.textContent?.trim() || ""
      );

  const method =
  language === "bn"
    ? JSON.parse(
        recipeData?.getAttribute(
          "data-method"
        ) || "[]"
      )
    : (() => {

        const methodHeading =
          document.getElementById(
            "method"
          );

        let method: string[] = [];

        if (methodHeading) {

          const methodList =
            methodHeading.nextElementSibling;

          if (
            methodList?.tagName === "OL"
          ) {

            method = Array.from(
              methodList.querySelectorAll(
                "li"
              )
            ).map(
              li =>
                li.textContent?.trim() ||
                ""
            );
          }
        }

        return method;

      })();

  const pdf = new jsPDF();
  	const logoImg = new Image();

	logoImg.src = logo.src;
	
	const watermarkImg = new Image();

	watermarkImg.src = watermark.src;


htmlPdf.setTextColor(0);

await waitForImage(
  watermarkImg
);

console.log("WATERMARK READY");

drawPageBackground(
  pdf,
  watermarkImg
);

drawFooter(pdf);
	await waitForImage(
  logoImg
);

console.log("LOGO READY");
	
htmlPdf.addImage(
  logoImg,
  "PNG",
  20,
  10,
  61,
  25
);

const heroImgElement =
  document.querySelector("main img") as HTMLImageElement;
  
  if (
  heroImgElement &&
  !heroImgElement.complete
) {

  await waitForImage(
    heroImgElement
  );
}
  
  if (heroImgElement) {

  const canvas = document.createElement("canvas");

  const maxWidth = 1200;

const scale =
  maxWidth /
  heroImgElement.naturalWidth;

canvas.width = maxWidth;

canvas.height =
  heroImgElement.naturalHeight *
  scale;

  const ctx = canvas.getContext("2d");

  if (ctx) {

    ctx.drawImage(
  heroImgElement,
  0,
  0,
  canvas.width,
  canvas.height
);

    const heroData =
  canvas.toDataURL(
    "image/jpeg",
    0.7
  );

    htmlPdf.addImage(
      heroData,
      "JPEG",
      20,
      60,
      170,
      95
    );
  }
}

  htmlPdf.setTextColor(242, 78, 7);
	htmlPdf.setFontSize(22);
	

  htmlPdf.setTextColor(112, 13, 29);

htmlPdf.setFont(
  "helvetica",
  "bold"
);

htmlPdf.setFontSize(34);

htmlPdf.text(
  title,
  105,
  50,
  {
    align: "center"
  }
);

htmlPdf.setFont(
  "helvetica",
  "normal"
);

  let y = 185;

  htmlPdf.setTextColor(112, 13, 29);

	htmlPdf.setFontSize(16);

	htmlPdf.text(
	  "INGREDIENTS",
	  20,
	  y
	);

  y += 10;
  
  htmlPdf.setTextColor(0);
htmlPdf.setFontSize(12);

  ingredients.forEach(item => {

  if (y > 270) {

  htmlPdf.addPage();

  drawPageBackground(
    pdf,
    watermarkImg
  );

  drawFooter(pdf);

  y = 20;

  htmlPdf.setTextColor(0);

  htmlPdf.setFontSize(12);
}
  
  htmlPdf.text(
    "• " + item,
    25,
    y
  );

  y += 8;
});

  y += 10;

  htmlPdf.setTextColor(112, 13, 29);

htmlPdf.setFontSize(16);

if (y > 240) {

  htmlPdf.addPage();

  drawPageBackground(
    pdf,
    watermarkImg
  );

  drawFooter(pdf);

  y = 20;
}

htmlPdf.setTextColor(112, 13, 29);

htmlPdf.setFontSize(16);

htmlPdf.text(
  "METHOD",
  20,
  y
);

y += 10;

htmlPdf.setTextColor(0);

htmlPdf.setFontSize(12);
  
  htmlPdf.setTextColor(0);
htmlPdf.setFontSize(12);

  method.forEach((step, index) => {

if (y > 270) {

  htmlPdf.addPage();

  drawPageBackground(
    pdf,
    watermarkImg
  );

  drawFooter(pdf);

  y = 20;

  htmlPdf.setTextColor(112, 13, 29);

  htmlPdf.setFontSize(16);

  htmlPdf.text(
    "METHOD",
    20,
    y
  );

  y += 10;

  htmlPdf.setTextColor(0);

  htmlPdf.setFontSize(12);
}

  htmlPdf.text(
    `${index + 1}. ${step}`,
    25,
    y
  );

  y += 8;
});
  
drawFooter(pdf);

  htmlPdf.save(
  language === "bn"
    ? "recipe-bn.pdf"
    : title.replace(
        /[^\w\s-]/g,
        ""
      ) + ".pdf"
);
  console.log("PDF SAVE");
};